# Governance Hub — environment variables

# Cloudflare tunnel token for hub.igcentral.com
# Get from: Cloudflare Zero Trust → Networks → Tunnels → Create a new tunnel
# Configure public hostname hub.igcentral.com → http://nginx:80
HUB_TUNNEL_TOKEN=

# MongoDB
HUB_MONGO_PASSWORD=hubpassword123

# Hub admin Basic Auth credentials
HUB_ADMIN_USERNAME=admin
HUB_ADMIN_PASSWORD=ChangeMe123!
