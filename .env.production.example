# ============================================================
# GLS Production Environment Variables
# ============================================================
# Copy this file to .env and fill in all values before deploying.
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env up -d
# ============================================================

# ── Public URL ──────────────────────────────────────────────
# The externally-reachable URL (used for OAuth callbacks, CORS, emails)
PUBLIC_URL=https://your-domain.com
BACKEND_BASE_URL=https://your-domain.com

# ── MongoDB ─────────────────────────────────────────────────
MONGO_PASSWORD=CHANGE_ME_strong_random_password
MONGO_DB_NAME=governance_led_storage_main

# ── JWT ─────────────────────────────────────────────────────
# Minimum 256-bit secret for HS256 signing. Generate with:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand

# ── Admin account (seeded on first startup) ─────────────────
ADMIN_EMAIL=admin@governanceledstore.co.uk
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── Anthropic (LLM classification) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Google OAuth (Drive connector + Google login) ───────────
# Register at: https://console.cloud.google.com/apis/credentials
# Redirect URIs:
#   ${PUBLIC_URL}/api/drives/google/callback
#   ${PUBLIC_URL}/api/auth/public/google/callback
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-CHANGE_ME

# ── MinIO (object storage) ─────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_BUCKET=gls-documents

# ── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_USER=gls_rabbitmq
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password

# ── Email (SMTP) ────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.office365.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=noreply@your-domain.com
EMAIL_PASSWORD=CHANGE_ME_email_password

# ── Cloudflare Tunnel ──────────────────────────────────────
TUNNEL_TOKEN=CHANGE_ME_cloudflare_tunnel_token

# ── Compose project name ───────────────────────────────────
COMPOSE_PROJECT_NAME=gls

# ── App environment ────────────────────────────────────────
APP_ENV=PRODUCTION

# ── Governance Hub ─────────────────────────────────────────
HUB_MONGO_PASSWORD=CHANGE_ME_hub_mongo_password
HUB_ADMIN_USERNAME=admin
HUB_ADMIN_PASSWORD=CHANGE_ME_hub_admin_password
GOVERNANCE_HUB_API_KEY=CHANGE_ME_hub_api_key
HUB_API_URL=http://governance-hub:8090
