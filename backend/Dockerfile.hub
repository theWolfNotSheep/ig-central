FROM eclipse-temurin:25-jdk AS build
WORKDIR /app

COPY .mvn .mvn
COPY mvnw .
COPY pom.xml .
COPY bom/pom.xml bom/
COPY igc-platform/pom.xml igc-platform/
COPY igc-governance/pom.xml igc-governance/
COPY igc-document/pom.xml igc-document/
COPY igc-document-processing/pom.xml igc-document-processing/
COPY igc-mcp-server/pom.xml igc-mcp-server/
COPY igc-llm-orchestration/pom.xml igc-llm-orchestration/
COPY igc-governance-enforcement/pom.xml igc-governance-enforcement/
COPY igc-app-assembly/pom.xml igc-app-assembly/
COPY igc-governance-hub/pom.xml igc-governance-hub/
COPY igc-governance-hub-app/pom.xml igc-governance-hub-app/

RUN ./mvnw dependency:go-offline -DskipTests -B -pl igc-governance-hub-app -am || true

COPY . .

RUN ./mvnw -DskipTests package -pl igc-governance-hub-app -am -o || ./mvnw -DskipTests package -pl igc-governance-hub-app -am

FROM eclipse-temurin:25-jre
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=build /app/igc-governance-hub-app/target/*.jar /app/app.jar
EXPOSE 8090
CMD ["java","-jar","/app/app.jar"]
